# Voice-to-Text Application Configuration

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# Database Configuration
# For SQLite (default):
DATABASE_URL=sqlite:///voice2text.db

# For PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/voice2text

# For MySQL:
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/voice2text

# Redis & Celery Configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_TIMEOUT=1800
CELERY_MAX_RETRIES=3

# Email Configuration (for password reset)
# Using Gmail SMTP as example:
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=Voice-to-Text <noreply@yourdomain.com>

# Note: For Gmail, you need to use an App Password instead of your regular password
# Generate one at: https://myaccount.google.com/apppasswords

# Whisper Model Configuration
# Options: tiny, base, small, medium, large
WHISPER_MODEL=base

# Upload Settings
MAX_FILE_SIZE_MB=500
UPLOAD_FOLDER=uploads

# File Storage
FILE_STORAGE_PATH=uploads
FILE_CLEANUP_HOURS=24

# Logging
LOG_LEVEL=INFO

# HuggingFace Token (for PyAnnote speaker diarization)
HF_TOKEN=your-huggingface-token